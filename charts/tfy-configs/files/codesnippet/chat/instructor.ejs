<%
  const USE_STREAM = (stream === true);
%>
import instructor
from openai import OpenAI
from pydantic import BaseModel

client = instructor.from_openai(
    OpenAI(
        base_url='<%= endpoint %>',
        api_key='<%= api_key %>',
        default_headers={
            'X-TFY-METADATA': '<%- JSON.stringify(custom_metadata) %>',
            'X-TFY-LOGGING-CONFIG': '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
            'X-TFY-GUARDRAILS': '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails: output_guardrails}) %>',<% } %><% if (include_routing_config) { %>
            'X-TFY-ROUTING-CONFIG': '<%- JSON.stringify(routing_config) %>',<% } %><% if (include_cache_config) { %>
            'X-TFY-CACHE-CONFIG': '<%- JSON.stringify(cache_config) %>',<% } %>
        },
    )
)

class Response(BaseModel):
    message: str

<% if (USE_STREAM) { %>
response, completion = client.chat.completions.create_with_completion(
    model='<%= model %>',
    messages=[
        {'role': 'system', 'content': 'You are an AI bot.'},
        {'role': 'user', 'content': '<%= prompt %>'},
    ],
    response_model=Response,
)
print(response.message)
<% } else { %>
response = client.chat.completions.create(
    model='<%= model %>',
    messages=[
        {'role': 'system', 'content': 'You are an AI bot.'},
        {'role': 'user', 'content': '<%= prompt %>'},
    ],
    response_model=Response,
)
print(response.message)
<% } %>
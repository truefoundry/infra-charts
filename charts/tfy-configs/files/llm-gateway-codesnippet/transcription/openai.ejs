from openai import OpenAI

BASE_URL = "<%= endpoint %>"
API_KEY = "<%= api_key %>"

client = OpenAI(
    api_key=API_KEY,
    base_url=BASE_URL,
)

with open("/path/to/audio.mp3", "rb") as audio_file:
    response = client.audio.transcriptions.create(
        model="<%= model %>",
        file=audio_file,
    )

print(response)

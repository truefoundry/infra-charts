<%
  const USE_STREAM = (stream === true);
%>
import asyncio
from pydantic_ai import Agent
from pydantic_ai.models.openai import OpenAIChatModel
from pydantic_ai.providers.openai import OpenAIProvider
from httpx import AsyncClient

model = OpenAIChatModel(
    '<%= model %>',
    provider=OpenAIProvider(
        base_url='<%= endpoint %>',
        api_key='<%= api_key %>',
        http_client=AsyncClient(
            headers={
                'X-TFY-METADATA': '<%- JSON.stringify(custom_metadata) %>',
                'X-TFY-LOGGING-CONFIG': '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
                'X-TFY-GUARDRAILS': '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails: output_guardrails}) %>',<% } %><% if (include_cache_config) { %>
                'X-TFY-CACHE-CONFIG': '<%- JSON.stringify(cache_config) %>',<% } %>
            }
        ),
    ),
)

agent = Agent(model)

<% if (USE_STREAM) { %>
async def main():
    async with agent.run_stream('<%= prompt %>') as result:
        async for text in result.stream_text(delta=True):
            print(text, end='', flush=True)

asyncio.run(main())
<% } else { %>
result = agent.run_sync('<%= prompt %>')
print(result.output)
<% } %>
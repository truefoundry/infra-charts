<%
  const USE_STREAM = (stream === true);
%>
import langroid.language_models as lm

config = lm.OpenAIGPTConfig(
    chat_model='<%= model %>',
    api_base='<%= endpoint %>',
    api_key='<%= api_key %>',
    stream=<%- USE_STREAM ? 'True' : 'False' %>,
    http_client_config={
        'headers': {
            'X-TFY-METADATA': '<%- JSON.stringify(custom_metadata) %>',
            'X-TFY-LOGGING-CONFIG': '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
            'X-TFY-GUARDRAILS': '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails: output_guardrails}) %>',<% } %><% if (include_cache_config) { %>
            'X-TFY-CACHE-CONFIG': '<%- JSON.stringify(cache_config) %>',<% } %>
        }
    },
)

llm = lm.OpenAIGPT(config)

response = llm.chat('<%= prompt %>')
<% if (!USE_STREAM) { %>
print(response.message)
<% } %>
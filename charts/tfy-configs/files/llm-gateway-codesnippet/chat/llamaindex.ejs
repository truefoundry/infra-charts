<%
  const indent = '    '.repeat(2);
  const USE_STREAM = (stream === true);
  let args = '';

  if (params) {
    Object.entries(params).forEach(([key, value]) => {
      if (key === 'stream') {
        return;
      }
      if (value !== undefined && value !== null) {
        if (typeof value === 'string') {
          args += `${indent}${key}="${value}",\n`;
        } else if (Array.isArray(value)) {
          args += `${indent}${key}=${JSON.stringify(value)},\n`;
        } else if (typeof value === 'boolean') {
          args += `${indent}${key}=${value ? 'True' : 'False'},\n`;
        } else {
          args += `${indent}${key}=${value},\n`;
        }
      }
    });
  }
-%>
from llama_index.core import Settings
from llama_index.llms.openai_like import OpenAILike
import json
<% if (include_output_schema) { %>
response_schema = json.loads('''<%- output_schema.structuredOutputResponse %>''')<% } %>
try:
    llm = OpenAILike(<% if (use_prompt_fqn) { %>
        model="<%= model %>",
        additional_kwargs={
          "extra_body":{
            "prompt_version_fqn": "<%= prompt_fqn %>"<% if (input_variables && Object.keys(input_variables).length > 0) { %>,
            "prompt_variables": <%- JSON.stringify(input_variables) %><% } %>
          }
      },<% } else { %>
        model="<%= model %>",
        additional_kwargs={<% if (include_output_schema) { %>
          "response_format":{"type": "json_schema","json_schema": {"name": "<%- output_schema.name %>", "schema": response_schema}},<% } %><% if (extra_body && extra_body.mcp_servers.length > 0) { %>
          "extra_body":{
            "mcp_servers": [<% extra_body.mcp_servers.forEach((server, index) => { %>
              {
                  "integration_fqn": "<%= server.integration_fqn %>",
                  "enable_all_tools": <%= server.enable_all_tools ? 'True' : 'False' %><% if (server.tools && server.tools.length > 0) { %>,
                  "tools": [<% server.tools.forEach((tool, toolIndex) => { %>{"name": "<%= tool.name %>"}<% if (toolIndex < server.tools.length - 1) { %>, <% } %><% }); %>]<% } %>
              }<% if (index < extra_body.mcp_servers.length - 1) { %>,<% } %><% }); %>
            ],
            "iteration_limit": <%= extra_body.iteration_limit %>
          }<% } %>
      },
<%- args.length > 0 ? args : '' %><% } %>        api_key="<%= api_key %>",
        api_base="<%= endpoint %>",
        default_headers={
          "X-TFY-METADATA": '<%- JSON.stringify(custom_metadata) %>',
          "X-TFY-LOGGING-CONFIG": '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
          "X-TFY-GUARDRAILS": '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails:
            output_guardrails})
           %>',<% } %><% if (include_routing_config) { %>
          "X-TFY-ROUTING-CONFIG": '<%- JSON.stringify(routing_config) %>',<% } %><% if (include_cache_config) { %>
          "X-TFY-CACHE-CONFIG": '<%- JSON.stringify(cache_config) %>' <% } %>
        },
        is_chat_model=True
    )

    Settings.llm = llm
    <% if (USE_STREAM) { %>
    full_text = ""
    for chunk in llm.stream_complete("<%= use_prompt_fqn ? '' : prompt %>"):
        print(chunk.delta, end="", flush=True)
        full_text += chunk.delta
    print()
    <% } else { %>
    response = llm.complete("<%= use_prompt_fqn ? '' : prompt %>")
    print(response.text)
    <% } %>
except Exception as e:
    print("An error occurred:", str(e))

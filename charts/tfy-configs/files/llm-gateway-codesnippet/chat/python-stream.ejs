<%
  const indent = '    '.repeat(3);
  const USE_STREAM = (stream === true);
  let args = '';

  if (params) {
    Object.entries(params).forEach(([key, value]) => {
      if (key === 'stream') {
        return;
      }
      if (value !== undefined && value !== null) {
        if (typeof value === 'string') {
          args += `${indent}"${key}": "${value}",\n`;
        } else if (Array.isArray(value)) {
          args += `${indent}"${key}": ${JSON.stringify(value)},\n`;
        } else if (typeof value === 'boolean') {
          args += `${indent}"${key}": ${value ? 'True' : 'False'},\n`;
        } else {
          args += `${indent}"${key}": ${value},\n`;
        }
      }
    });
  }

  args += `${indent}"stream": ${USE_STREAM ? 'True' : 'False'}`;

-%>
import requests
import json
# Note: use sseclient-py and NOT sseclient
import sseclient

USE_STREAM = <%- USE_STREAM ? 'True' : 'False' %>

try:
    response = requests.post(
        "<%= endpoint %>/chat/completions",
        headers={
            "Authorization": "Bearer <%= api_key %>",
            "X-TFY-METADATA": '<%- JSON.stringify(custom_metadata) %>',
            "X-TFY-LOGGING-CONFIG": '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
            "X-TFY-GUARDRAILS": '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails:
              output_guardrails}) %>',<% } %><% if (include_routing_config) { %>
            "X-TFY-ROUTING-CONFIG": '<%- JSON.stringify(routing_config) %>',<% } %><% if (include_cache_config) { %>
            "X-TFY-CACHE-CONFIG": '<%- JSON.stringify(cache_config) %>'<% } %>
        },
        json={<% if (use_prompt_fqn) { %>
            "model": "<%= model %>",
            "messages": [],
            "stream": USE_STREAM,
            "prompt_version_fqn": "<%= prompt_fqn %>"<% if (input_variables && Object.keys(input_variables).length > 0) { %>,
            "prompt_variables": <%- JSON.stringify(input_variables) %><% } %><% } else { %>
            "model": "<%= model %>",
            "messages": [
                {"role": "system", "content": "You are an AI bot."},
                {"role": "user", "content": "<%= prompt %>"}
            ],
<%- args %><% } %>
        },
        stream=USE_STREAM
    )
    response.raise_for_status()

except requests.exceptions.HTTPError as http_error:
    print("HTTP error occurred:", http_error)
<% if (USE_STREAM) { %>
client = sseclient.SSEClient(response)
for event in client.events():
    if event.data != "[DONE]":
        data = json.loads(event.data)
        if data['choices'] and len(data['choices']) > 0:
            if 'delta' in data['choices'][0] and 'content' in data['choices'][0]['delta']:
                print(data['choices'][0]['delta']['content'], end="", flush=USE_STREAM)
<% } else { %>
data = response.json()
if data.get('choices') and len(data['choices']) > 0:
    content = data['choices'][0]['message']['content']
    print(content)
<% } %>

<%
  const USE_STREAM = (stream === true);
%>
from swarm import Swarm, Agent
from openai import OpenAI

client = OpenAI(
    base_url='<%= endpoint %>',
    api_key='<%= api_key %>',
    default_headers={
        'X-TFY-METADATA': '<%- JSON.stringify(custom_metadata) %>',
        'X-TFY-LOGGING-CONFIG': '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
        'X-TFY-GUARDRAILS': '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails: output_guardrails}) %>',<% } %><% if (include_cache_config) { %>
        'X-TFY-CACHE-CONFIG': '<%- JSON.stringify(cache_config) %>',<% } %>
    },
)

swarm_client = Swarm(client=client)

agent = Agent(
    name='Assistant',
    instructions='You are a helpful assistant.',
    model='<%= model %>',
)

<% if (USE_STREAM) { %>
response = swarm_client.run(
    agent=agent,
    messages=[{'role': 'user', 'content': '<%= prompt %>'}],
    stream=True,
)
for chunk in response:
    if isinstance(chunk, dict) and 'content' in chunk and chunk['content']:
        print(chunk['content'], end='', flush=True)
<% } else { %>
response = swarm_client.run(
    agent=agent,
    messages=[{'role': 'user', 'content': '<%= prompt %>'}],
)
print(response.messages[-1]['content'])
<% } %>
<%
  const indent = '    '.repeat(1);
  const USE_STREAM = (stream === true);
  let args = '';

  if (params) {
    Object.entries(params).forEach(([key, value]) => {
      if (key === 'stream') {
        return;
      }
      if (value !== undefined && value !== null) {
        if (typeof value === 'string') {
          args += `${indent}${key}="${value}",\n`;
        } else if (Array.isArray(value)) {
          args += `${indent}${key}=${JSON.stringify(value)},\n`;
        } else if (typeof value === 'boolean') {
          args += `${indent}${key}=${value ? 'True' : 'False'},\n`;
        } else {
          args += `${indent}${key}=${value},\n`;
        }
      }
    });
  }
  args += `${indent}stream=${USE_STREAM ? 'True' : 'False'},`;
-%>
from openai import OpenAI<% if (include_output_schema) { %>
import json
response_schema = json.loads('''<%- output_schema.structuredOutputResponse %>''')<% } %>
client = OpenAI(api_key="<%= api_key %>", base_url="<%= endpoint %>")

stream = client.chat.completions.create(<% if (use_prompt_fqn) { %>
    messages=[],
    model="<%= model %>",<% } else { %>
    messages=[
        {"role": "system", "content": "You are an AI bot."},
        {"role": "user", "content": "<%= prompt %>"},
    ],
    model="<%= model %>",<% if (include_output_schema) { %>
    response_format={"type": "json_schema","json_schema": {"name": "<%- output_schema.name %>", "schema": response_schema}},<% } %><% } %>
<%- args %>
    extra_headers={
        "X-TFY-METADATA": '<%- JSON.stringify(custom_metadata) %>',
        "X-TFY-LOGGING-CONFIG": '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',<% if (include_guardrails) { %>
        "X-TFY-GUARDRAILS": '<%- JSON.stringify({llm_input_guardrails: input_guardrails, llm_output_guardrails:
          output_guardrails}) %>', <% } %><% if (include_routing_config) { %>
        "X-TFY-ROUTING-CONFIG": '<%- JSON.stringify(routing_config) %>',<% } %><% if (include_cache_config) { %>
        "X-TFY-CACHE-CONFIG": '<%- JSON.stringify(cache_config) %>' <% } %>
    },<% if (use_prompt_fqn) { %>
    extra_body={
        "prompt_version_fqn": "<%= prompt_fqn %>"<% if (input_variables && Object.keys(input_variables).length > 0) { %>,
        "prompt_variables": <%- JSON.stringify(input_variables) %><% } %>
    },<% } else if (extra_body && extra_body.mcp_servers.length > 0) { %>
    extra_body={
      "mcp_servers": [
          <%- extra_body.mcp_servers.map(server => `{
              "integration_fqn": "${server.integration_fqn}",
              "enable_all_tools": ${server.enable_all_tools ? 'True' : 'False'}${server.tools && server.tools.length > 0 ? `,
              "tools": [${server.tools.map(tool => `{"name": "${tool.name}"}`).join(', ')}]` : ''}
          }`).join(',\n            ') %>
      ],
      "iteration_limit": <%= extra_body.iteration_limit %>,
  },<% } %>
)

<% if (USE_STREAM) { %>
for chunk in stream:
    if (
        chunk.choices
        and len(chunk.choices) > 0
        and chunk.choices[0].delta.content is not None
    ):
        print(chunk.choices[0].delta.content, end="", flush=<%- USE_STREAM ? 'True' : 'False' %>)
<% } else { %>
print(stream.choices[0].message.content)
<% } %>

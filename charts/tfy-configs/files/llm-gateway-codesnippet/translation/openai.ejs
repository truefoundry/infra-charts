from openai import OpenAI

BASE_URL = "<%= endpoint %>"
API_KEY = "<%= api_key %>"

client = OpenAI(
    api_key=API_KEY,
    base_url=BASE_URL,
)

audio_file = open("/path/to/file/audio.mp3", "rb")

translation = client.audio.translations.create(
    model="<%= model %>",
    file=audio_file,
)

print(translation.text)

import requests
import langgraph.graph as lg

def rerank(state):
    response = requests.post(
        "<%= endpoint %>/v2/rerank",
        headers={
            "Authorization": "Bearer <%= api_key %>",
            "X-TFY-METADATA": '<%- JSON.stringify(custom_metadata) %>',
            "X-TFY-LOGGING-CONFIG": '{"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}',
            "Content-Type": "application/json"
        },
        json={
          "model": "<%= model %>",
          "query": "<%= query %>",
          "documents": <%- JSON.stringify(documents) %>,
          "return_documents": <%= return_documents === true ? 'True' : 'False' %>,
          "raw_scores": <%= raw_scores === true ? 'True' : 'False' %>,
          "top_n": <%= top_n %>
        }
    )
    response.raise_for_status()

    result = response.json()
    print(result)

    return response.json()

graph = lg.Graph()
graph.add_node("rerank", rerank)
graph.set_entry_point("rerank")

app = graph.compile()

if __name__ == "__main__":
    for output in app.stream({}):
        pass

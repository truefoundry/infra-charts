curl '<%= endpoint %>/v2/rerank' \
    -H 'Content-Type: application/json' \
    -H 'Authorization: Bearer <%= api_key %>' \
    -H 'X-TFY-METADATA: <%- JSON.stringify(custom_metadata) %>' \
    -H 'X-TFY-LOGGING-CONFIG: {"enabled": <%- request_logging %><% if (request_logging_tracing_project_fqn) { %>, "tracing_project_fqn": "<%= request_logging_tracing_project_fqn %>"<% } %>}' \
    -d '{
        "model": "<%= model %>",
        "query": "<%= query %>",
        "documents": <%- JSON.stringify(documents) %>,
        "top_n": <%= top_n %>,
        "return_documents": <%= return_documents %>,
        "raw_scores": <%= raw_scores %>
    }'
